# ============================================================
#  CHRIST LE BON BERGER — Variables d'environnement
#  Copiez ce fichier en `.env` et remplissez les valeurs.
#  Ne commitez JAMAIS le fichier `.env` (il est dans .gitignore).
# ============================================================


# ────────────────────────────────────────────────────────────
#  SUPABASE  (obligatoire)
#  → Dashboard Supabase : Settings > API
# ────────────────────────────────────────────────────────────

# URL de votre projet Supabase (ex: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Clé anonyme publique (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=


# ────────────────────────────────────────────────────────────
#  SITE
# ────────────────────────────────────────────────────────────

# URL publique canonique du site (sans slash final)
# Utilisée pour : SEO, Open Graph, sitemap XML, liens dans les emails
VITE_SITE_URL=https://www.christ-le-bon-berger.com

# Email de contact de l'association
# Utilisé comme destinataire de secours si la fonction Edge Brevo échoue
VITE_CONTACT_EMAIL=lebonberger025@gmail.com


# ────────────────────────────────────────────────────────────
#  PDF PROXY  (Vercel uniquement)
# ────────────────────────────────────────────────────────────

# En production sur Vercel : mettre "true" pour passer les PDFs
# par /api/pdf-proxy (évite les erreurs CORS avec Supabase Storage).
# En développement local : laisser "false" (URL Supabase directe).
VITE_PDF_PROXY=false


# ============================================================
#  VARIABLES SUPABASE EDGE FUNCTIONS  (côté serveur Deno)
#  → À configurer dans : Dashboard Supabase > Edge Functions > Secrets
#  → Ces variables NE sont PAS préfixées VITE_ et ne vont PAS dans .env
#    Elles sont lues par Deno.env.get() dans les fonctions Supabase.
# ============================================================

# ── Brevo (envoi d'emails transactionnels et newsletters) ───
# Clé API Brevo
#   → https://app.brevo.com > Mon compte > Clés API SMTP & API
#   Nom du secret Supabase : BREVO_API_KEY
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email expéditeur vérifié dans Brevo (doit être validé dans votre compte Brevo)
#   Nom du secret Supabase : BREVO_SENDER_EMAIL
# BREVO_SENDER_EMAIL=contact@christ-le-bon-berger.com

# Nom affiché comme expéditeur dans les emails
#   Nom du secret Supabase : BREVO_SENDER_NAME
# BREVO_SENDER_NAME=Christ Le Bon Berger

# Email de réception des messages du formulaire de contact
#   Nom du secret Supabase : BREVO_CONTACT_TO_EMAIL
# BREVO_CONTACT_TO_EMAIL=lebonberger025@gmail.com

# ── CORS (optionnel) ────────────────────────────────────────
# Origine supplémentaire autorisée pour les Edge Functions
# (votre domaine custom si différent de christ-le-bon-berger.com)
#   Nom du secret Supabase : ALLOWED_ORIGIN
# ALLOWED_ORIGIN=https://votre-domaine-custom.com
